{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "agentops_data_drift_score",
          "legendFormat": "Drift Score"
        }
      ],
      "title": "Data Drift Score Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "No Drift" } }, "type": "value" },
            { "options": { "1": { "text": "DRIFT DETECTED" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "agentops_data_drift_detected",
          "legendFormat": "Drift Status"
        }
      ],
      "title": "Drift Alert",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "agentops_drifted_features_count",
          "legendFormat": "Drifted Features"
        }
      ],
      "title": "Drifted Features Count",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "increase(agentops_agent_runs_total[1h])",
          "legendFormat": "{{trigger_reason}}"
        }
      ],
      "title": "Pipeline Runs (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "agentops_retraining_total",
          "legendFormat": "Retraining Runs"
        },
        {
          "expr": "agentops_deployment_swaps_total",
          "legendFormat": "Model Deployments"
        }
      ],
      "title": "Retraining & Deployments",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agentops_agent_pipeline_duration_seconds_bucket[5m]))",
          "legendFormat": "Pipeline Duration (p95)"
        }
      ],
      "title": "Pipeline Duration",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentops", "drift", "agents"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AgentOps - Agent Pipeline & Drift",
  "uid": "agentops-drift-pipeline"
}
